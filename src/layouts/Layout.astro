---
import '@fontsource/playfair-display/400.css';
import '@fontsource/playfair-display/700.css';
import '@fontsource/montserrat/400.css';
import '@fontsource/montserrat/600.css';
import Navigation from '../components/Navigation.astro';

interface Props {
  title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="fr">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content="Horus Productions - Production Créative de Films" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
  </head>
  <body class="bg-[#0a192f] text-white">
    <!-- En-tête transparent et fixe -->
    <header class="fixed top-0 left-0 right-0 p-4 bg-transparent flex items-center justify-between z-10">
      <!-- Logo -->
      <img src="/1045.png" alt="Horus Productions Logo" class="w-12 h-auto mr-4" />
      <!-- Titre injecté depuis la prop -->
      <h1 class="text-4xl font-bold text-white">{title}</h1>
    </header>

    <Navigation />
    <slot />
  </body>
</html>

<style is:global>
  :root {
    --font-heading: 'Playfair Display', serif;
    --font-body: 'Montserrat', sans-serif;
  }
  html {
    scroll-behavior: smooth;
  }
  body {
    font-family: var(--font-body);
    overflow-x: hidden;
  }
  h1, h2, h3, h4, h5, h6 {
    font-family: var(--font-heading);
  }

  /* En-tête fixe et transparent */
  header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 10;
    padding: 1rem;
    background-color: transparent; /* Fond transparent */
  }

  /* Ajout d'un espacement suffisant en haut pour éviter que le contenu ne soit masqué sous l'en-tête */
  body {
    margin-top: 80px;  /* Ajustez selon la hauteur de votre en-tête */
  }

  /* Style du titre */
  h1 {
    font-size: 2.5rem;
    color: white;
  }

  /* Style pour le logo */
  img {
    width: 50px;  /* Ajustez la taille du logo */
    height: auto;
    margin-right: 10px;
  }
</style>
