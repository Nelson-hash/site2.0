---
const projects = [
  {
    title: "Nuit Blanche",
    subtitle: "(en cours)",
    imagePath: "/production-image.jpg"
  },
  {
    title: "Papi Teddy Bear & Pense",
    subtitle: "Qishui",
    imagePath: "/team-image.jpg"
  },
  {
    title: "Elias LCG",
    subtitle: "",
    imagePath: "/production-image.jpg"
  }
];
---

<section class="py-20 bg-[#0a192f]">
  <div class="max-w-7xl mx-auto px-4">
    <div class="space-y-12">
      {projects.map((project, index) => (
        <div class="group cursor-pointer">
          <h3 class="text-4xl font-bold mb-2 hover:text-gold transition-colors">
            {project.title} 
            {project.subtitle && <span class="text-gold">{project.subtitle}</span>}
          </h3>
          <div class="mt-4 overflow-hidden">
            <img 
              src={project.imagePath} 
              alt={project.title}
              class="w-full h-[600px] object-cover transform transition-transform duration-700 group-hover:scale-105"
            />
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .text-gold {
    color: #D4AF37;
  }
</style>